generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  photos    Photo[]
  galleries Gallery[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  photos    Photo[]
}

model Photo {
  id          String   @id @default(cuid())
  title       String?
  description String?
  url         String
  createdAt   DateTime @default(now())
  isCover     Boolean  @default(false)
  isPortrait  Boolean  @default(false)
  isAboutPicture Boolean @default(false)

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  galleries   GalleryPhoto[]
}

model Gallery {
  id        String   @id @default(cuid())
  name      String
  description String @default("")
  token     String   @unique @default(cuid())
  createdAt DateTime @default(now())
  isPremium Boolean @default(false)

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  photos    GalleryPhoto[]
}

model GalleryPhoto {
  galleryId String
  gallery   Gallery @relation(fields: [galleryId], references: [id])
  isGalleryCover Boolean @default(false)

  photoId   String
  photo     Photo   @relation(fields: [photoId], references: [id])

  @@id([galleryId, photoId])
}

model SiteConfig {
  id              String @id @default(cuid())
  // Hero
  heroSubtitle    String @default("")
  heroName        String @default("")
  heroTagline     String @default("")
  // Bio (page About)
  bioTitle        String @default("")
  bioParagraph1   String @default("")
  bioParagraph2   String @default("")
  // Story (page About)
  storyParagraph1 String @default("")
  storyParagraph2 String @default("")
  // Dark section (homepage)
  darkQuote       String @default("")
  darkQuoteAuthor String @default("")
}

model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  email     String?
  used      Boolean   @default(false)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
}