
generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?   // optionnel : les comptes OAuth n'ont pas de mot de passe
  name          String?   // ajout NextAuth v5
  emailVerified DateTime? // ajout NextAuth v5
  image         String?   // ajout NextAuth v5
  createdAt     DateTime  @default(now())
  tempCode      String?
  tempCodeExpiry DateTime?

  subdomain        String?   @unique // ex: "jean"
  customDomain     String?   @unique // ex: "www.jean-photo.fr"

  cloudinaryName   String?
  cloudinaryKey    String?
  cloudinarySecret String?

  tarifs Tarif[]
  accounts  Account[]
  sessions  Session[]
  photos    Photo[]
  galleries Gallery[]
  siteConfig SiteConfig?
}

// Modèles requis par NextAuth v5 / PrismaAdapter
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Tarif {
  id            String   @id @default(cuid())
  title         String
  description   String
  price         String   // "150 €" ou "Sur devis"
  photoUrl      String?
  photoPublicId String?  // pour supprimer de Cloudinary si le tarif est supprimé
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Contenu ───────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  photos Photo[]
}

model Photo {
  id             String   @id @default(cuid())
  title          String?
  url            String
  publicId       String?  @unique // identifiant Cloudinary (optionnel pour les photos existantes)
  isCover        Boolean  @default(false)
  isPortrait     Boolean  @default(false)
  isAboutPicture1  Boolean  @default(false)
  isAboutPicture2  Boolean  @default(false)
  isAboutPicture3  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  userId     String
  user       User      @relation(fields: [userId], references: [id])
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  galleries GalleryPhoto[]
}

model Gallery {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  token       String   @unique @default(cuid()) // lien de partage public
  isPremium   Boolean  @default(false)
  isPrivate   Boolean  @default(false) // ajout back-office
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  expiresAt   DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  photos GalleryPhoto[]
  guests GalleryGuest[]
}

model GalleryPhoto {
  galleryId      String
  photoId        String
  isGalleryCover Boolean @default(false)
  order          Int     @default(0) // ajout back-office : ordre d'affichage

  gallery Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  photo   Photo   @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@id([galleryId, photoId])
}

// ─── Configuration ─────────────────────────────────────────────────────────

model SiteConfig {
  id              String @id @default(cuid())
  // Hero (page d'accueil)
  heroSubtitle    String @default("")
  heroName        String @default("")
  heroTagline     String @default("")
  // Bio (page About)
  bioTitle        String @default("")
  bioParagraph1   String @default("")
  bioParagraph2   String @default("")
  // Story (page About)
  storyParagraph1 String @default("")
  storyParagraph2 String @default("")
  // Section sombre (page d'accueil)
  darkQuote       String @default("")
  darkQuoteAuthor String @default("")

  userId          String @unique 
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  email     String?
  used      Boolean   @default(false)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
}

model GalleryGuest {
  id             String  @id @default(cuid())   
  @@unique([galleryId, email])
  galleryId      String 
  email          String
  gallery        Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  lastVisitedAt  DateTime?

  secretPasswords SecretPassword[]
}

model SecretPassword {
  used Boolean @default(false)
  id            String @id @default(cuid())
  code          String
  expiresAt     DateTime
  guestId       String
  galleryGuest GalleryGuest @relation(fields: [guestId], references: [id], onDelete: Cascade)
  
}
